# Copy to server/.env on your production host — never commit real secrets.

NODE_ENV=production
PORT=3000

# Required
MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/moving-mate
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET

# Public URL of the app (used in email links)
CLIENT_URL=https://yourdomain.com

# Mock payments for production testing (switch to stripe later)
PAYMENTS_PROVIDER=mock

# Required: server-side geocoding for pickupDistrict
GOOGLE_MAPS_API_KEY=

# Required: transactional email
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=Moving Mate <noreply@yourdomain.com>

# Optional: push notifications
# FIREBASE_SERVICE_ACCOUNT_PATH=./config/firebase-service-account.json

# Only if frontend is on a different origin than the API
# EXTRA_ALLOWED_ORIGINS=https://app.yourdomain.com

# Node serves Angular from dist/ (default). Set false if nginx serves static files.
# SERVE_CLIENT=false

# Do NOT enable on public production
# ENABLE_TEST_ROUTES=true
