# Copy to .env — never commit .env
NODE_ENV=development
PORT=3000

# Development: defaults exist in server/config/env.js for local Mongo + JWT.
# Production: REQUIRED — no mongodb:// or JWT fallbacks.
MONGODB_URI=mongodb://localhost:27017/moving-mate
JWT_SECRET=change-me-in-production

# Production: JWT_SECRET must be a strong random value (never "dev-secret-change-in-production").
CLIENT_URL=http://localhost:4200
# Email links (forgot password, driver welcome). In production use your public site URL.
# PUBLIC_APP_URL=https://moving-mate.com

# Payments: mock (default) for production testing until Stripe is integrated.
# Later: PAYMENTS_PROVIDER=stripe + STRIPE_SECRET_KEY + STRIPE_WEBHOOK_SECRET
PAYMENTS_PROVIDER=mock

# When NODE_ENV=production, Node serves dist/moving-mate/browser from the same port (after `npm run build:prod`).
# Set SERVE_CLIENT=false if nginx or a CDN hosts the Angular build separately.
# SERVE_CLIENT=true

# Production email (required when NODE_ENV is not development)
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=SG.your_sendgrid_api_key
# EMAIL_FROM=Moving Mate <noreply@example.com>
#
# Render FREE tier blocks outbound SMTP ports 25/465/587. In production, when SMTP_PASS
# is a SendGrid API key (SG.*) the app automatically uses SendGrid HTTP API (port 443).
# Optional override: SENDGRID_API_KEY=SG.... or EMAIL_TRANSPORT=sendgrid_api|smtp
# On Render, set EMAIL_TRANSPORT=sendgrid_api (see render.yaml) — SMTP ports are blocked on free tier.

# Required in production/staging: Geocoding (derive pickupDistrict when client omits it) — mapsService.js
# Prefer GOOGLE_MAPS_API_KEY; alias: MAPS_API_KEY. Never commit real keys.
GOOGLE_MAPS_API_KEY=
# MAPS_API_KEY=

# Firebase (optional) — path to service account JSON, or place file in server/config/
# Firebase Admin (server push). Option A — local file:
# FIREBASE_SERVICE_ACCOUNT_PATH=config/firebase-service-account.json
# Option B — Render secret file (filename firebase-service-account.json):
# FIREBASE_SERVICE_ACCOUNT_PATH=/etc/secrets/firebase-service-account.json
# Option C — inline JSON env var (avoid newlines; use Secret File when possible):
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Test routes under /api/test/* when NODE_ENV is not production, OR set ENABLE_TEST_ROUTES=true (needed if NODE_ENV=production locally).
#
# CORS: production static allow-list includes http://localhost:4200 and http://localhost:3000 (see server/config/cors.js).
# Add your public app URL: EXTRA_ALLOWED_ORIGINS=https://app.yourdomain.com
