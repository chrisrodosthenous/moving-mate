<!doctype html>
<html>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Verification update</title>
  </head>
  <body style="margin:0;padding:0;background:#f8fafc;font-family:Arial,sans-serif;color:#0f172a;">
    <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="background:#f8fafc;padding:24px 0;">
      <tr>
        <td align="center">
          <table role="presentation" width="600" cellspacing="0" cellpadding="0" style="max-width:600px;width:100%;background:#ffffff;border:1px solid #e2e8f0;border-radius:10px;overflow:hidden;">
            <tr>
              <td style="background:#0f172a;padding:20px 24px;color:#ffffff;font-size:20px;font-weight:700;">Moving Mate</td>
            </tr>
            <tr>
              <td style="padding:24px;">
                <h1 style="margin:0 0 12px;font-size:22px;line-height:1.3;">Verification update</h1>
                <p style="margin:0 0 12px;font-size:14px;line-height:1.6;">Hello {{firstName}},</p>
                {{#if rejectionReason}}
                <p style="margin:0 0 12px;font-size:14px;line-height:1.6;color:#b91c1c;background:#fef2f2;border:1px solid #fecaca;border-radius:8px;padding:12px 14px;">
                  <strong>Rejection reason:</strong><br />{{rejectionReason}}
                </p>
                {{else}}
                <p style="margin:0 0 12px;font-size:14px;line-height:1.6;color:#64748b;">No additional details were provided.</p>
                {{/if}}
                <p style="margin:0 0 18px;font-size:14px;line-height:1.6;">
                  Please review the feedback above, update your documents if needed, and submit again from your profile.
                </p>
                <a href="{{profileUrl}}" style="display:inline-block;background:#0ea5e9;color:#ffffff;text-decoration:none;padding:10px 16px;border-radius:8px;font-size:14px;font-weight:700;">
                  Update profile
                </a>
                <p style="margin:20px 0 0;font-size:12px;color:#64748b;">If the button does not work, copy this URL:<br />{{profileUrl}}</p>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
