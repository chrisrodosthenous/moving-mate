<!doctype html>
<html>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>24h Order Reminder</title>
  </head>
  <body style="margin:0;padding:0;background:#f8fafc;font-family:Arial,sans-serif;color:#000F11;">
    <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="background:#f8fafc;padding:24px 0;">
      <tr>
        <td align="center">
          <table role="presentation" width="620" cellspacing="0" cellpadding="0" style="max-width:620px;width:100%;background:#ffffff;border:1px solid #e2e8f0;border-radius:10px;overflow:hidden;">
            <tr>
              <td style="background:#000F11;padding:20px 24px;color:#ffffff;font-size:20px;font-weight:700;">Moving Mate</td>
            </tr>
            <tr>
              <td style="padding:24px;">
                <h1 style="margin:0 0 12px;font-size:22px;line-height:1.3;">Reminder: your move is in 24 hours</h1>
                <p style="margin:0 0 14px;font-size:14px;line-height:1.6;">Hello {{firstName}}, this is your scheduled order reminder.</p>
                <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="border:1px solid #e2e8f0;border-radius:8px;overflow:hidden;">
                  <tr><td style="padding:11px 14px;background:#f8fafc;font-size:12px;color:#475569;">Order ID</td><td style="padding:11px 14px;text-align:right;font-size:13px;font-weight:700;">{{orderId}}</td></tr>
                  <tr><td style="padding:11px 14px;background:#f8fafc;font-size:12px;color:#475569;">Scheduled Date/Time</td><td style="padding:11px 14px;text-align:right;font-size:13px;">{{scheduledAt}}</td></tr>
                  <tr><td style="padding:11px 14px;background:#f8fafc;font-size:12px;color:#475569;">Pickup</td><td style="padding:11px 14px;text-align:right;font-size:13px;">{{pickupAddress}}</td></tr>
                  <tr><td style="padding:11px 14px;background:#f8fafc;font-size:12px;color:#475569;">Dropoff</td><td style="padding:11px 14px;text-align:right;font-size:13px;">{{dropoffAddress}}</td></tr>
                </table>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
  </html>
