<!doctype html>
<html>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Order Confirmation</title>
  </head>
  <body style="margin:0;padding:0;background:#f8fafc;font-family:Arial,sans-serif;color:#000F11;">
    <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="background:#f8fafc;padding:24px 0;">
      <tr>
        <td align="center">
          <table role="presentation" width="640" cellspacing="0" cellpadding="0" style="max-width:640px;width:100%;background:#ffffff;border:1px solid #e2e8f0;border-radius:10px;overflow:hidden;">
            <tr>
              <td style="background:#000F11;padding:20px 24px;color:#ffffff;font-size:20px;font-weight:700;">Moving Mate</td>
            </tr>
            <tr>
              <td style="padding:24px;">
                <h1 style="margin:0 0 12px;font-size:22px;line-height:1.3;">Order confirmation</h1>
                <p style="margin:0 0 12px;font-size:14px;line-height:1.6;">Hello {{firstName}}, your request has been created.</p>

                <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="border:1px solid #e2e8f0;border-radius:8px;overflow:hidden;margin:16px 0;">
                  <tr><td style="padding:12px 14px;background:#f8fafc;font-size:12px;color:#475569;">Order ID</td><td style="padding:12px 14px;text-align:right;font-size:13px;font-weight:700;">{{orderId}}</td></tr>
                  <tr><td style="padding:12px 14px;background:#f8fafc;font-size:12px;color:#475569;">Pickup</td><td style="padding:12px 14px;text-align:right;font-size:13px;">{{pickupAddress}}</td></tr>
                  <tr><td style="padding:12px 14px;background:#f8fafc;font-size:12px;color:#475569;">Dropoff</td><td style="padding:12px 14px;text-align:right;font-size:13px;">{{dropoffAddress}}</td></tr>
                  <tr><td style="padding:12px 14px;background:#f8fafc;font-size:12px;color:#475569;">Small Boxes</td><td style="padding:12px 14px;text-align:right;font-size:13px;">{{smallBoxes}}</td></tr>
                  <tr><td style="padding:12px 14px;background:#f8fafc;font-size:12px;color:#475569;">Medium Boxes</td><td style="padding:12px 14px;text-align:right;font-size:13px;">{{mediumBoxes}}</td></tr>
                  <tr><td style="padding:12px 14px;background:#f8fafc;font-size:12px;color:#475569;">Large Boxes</td><td style="padding:12px 14px;text-align:right;font-size:13px;">{{largeBoxes}}</td></tr>
                  <tr><td style="padding:12px 14px;background:#f1f5f9;font-size:12px;color:#334155;font-weight:700;">Total Boxes</td><td style="padding:12px 14px;text-align:right;font-size:13px;font-weight:700;">{{totalBoxes}}</td></tr>
                  <tr><td style="padding:12px 14px;background:#f1f5f9;font-size:12px;color:#334155;font-weight:700;">Price</td><td style="padding:12px 14px;text-align:right;font-size:13px;font-weight:700;">EUR {{price}}</td></tr>
                </table>

                <p style="margin:0;font-size:12px;color:#64748b;">You will receive updates as soon as a driver accepts your request.</p>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
  </html>
