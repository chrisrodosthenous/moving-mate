<!doctype html>
<html>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Withdrawal completed</title>
  </head>
  <body style="margin:0;padding:0;background:#f8fafc;font-family:Arial,sans-serif;color:#0a2540;">
    <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="background:#f8fafc;padding:24px 0;">
      <tr>
        <td align="center">
          <table role="presentation" width="640" cellspacing="0" cellpadding="0" style="max-width:640px;width:100%;background:#ffffff;border:1px solid #e2e8f0;border-radius:10px;overflow:hidden;">
            <tr>
              <td style="background:#0a2540;padding:20px 24px;color:#ffffff;font-size:20px;font-weight:700;">Moving Mate</td>
            </tr>
            <tr>
              <td style="padding:24px;">
                <h1 style="margin:0 0 12px;font-size:22px;line-height:1.3;">Withdrawal completed</h1>
                <p style="margin:0 0 12px;font-size:14px;line-height:1.6;">Hello {{firstName}}, your {{recipientLabel}} withdrawal has been processed (mock payout).</p>

                <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="border:1px solid #e2e8f0;border-radius:8px;overflow:hidden;margin:16px 0;">
                  <tr><td style="padding:12px 14px;background:#f8fafc;font-size:12px;color:#475569;">Amount</td><td style="padding:12px 14px;text-align:right;font-size:13px;font-weight:700;">EUR {{amount}}</td></tr>
                  <tr><td style="padding:12px 14px;background:#f8fafc;font-size:12px;color:#475569;">Remaining balance</td><td style="padding:12px 14px;text-align:right;font-size:13px;font-weight:700;">EUR {{remainingBalance}}</td></tr>
                  <tr><td style="padding:12px 14px;background:#f8fafc;font-size:12px;color:#475569;">Reference</td><td style="padding:12px 14px;text-align:right;font-size:13px;font-family:monospace;">{{payoutId}}</td></tr>
                </table>

                <p style="margin:0;font-size:12px;color:#64748b;">This is a simulated bank transfer for testing. Live Stripe payouts will replace this flow in production.</p>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
